local Library = {}

function Library:CreateWindow(HubTitle, HubSubtitle)
    local Players = game:GetService("Players")
    local UIS = game:GetService("UserInputService")
    local CoreGui = game:GetService("CoreGui")
    local TweenService = game:GetService("TweenService")

    local Player = Players.LocalPlayer or Players:GetPlayers()[1] or Players.PlayerAdded:Wait()
    local Minimized = false

    -- Multi-executor fallback chain
    local ParentFolder
    local successHui, hui = pcall(function() return gethui and gethui() end)
    local successClone, coreClone = pcall(function() return cloneref and cloneref(CoreGui) end)
    
    if successHui and hui then
        ParentFolder = hui
    elseif successClone and coreClone then
        ParentFolder = coreClone
    else
        local successCore, core = pcall(function() return CoreGui end)
        if successCore and core and pcall(function() return core.Name end) then
            ParentFolder = core
        else
            ParentFolder = Player:WaitForChild("PlayerGui", 10)
        end
    end

    if not ParentFolder then return nil end

    pcall(function()
        if ParentFolder:FindFirstChild("UniversalGui") then
            ParentFolder.UniversalGui:Destroy()
        end
    end)

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "UniversalGui"
    ScreenGui.ResetOnSpawn = false
    
    pcall(function() ScreenGui.DisplayOrder = 999999 end)
    pcall(function() ScreenGui.IgnoreGuiInset = true end)
    ScreenGui.Parent = ParentFolder

    -- Metallic Silver Shiny Theme
    local Theme = {
        MainBg = Color3.fromRGB(15, 15, 18),
        ElementBg = Color3.fromRGB(22, 22, 26),
        TextPrimary = Color3.fromRGB(255, 255, 255),
        TextSecondary = Color3.fromRGB(180, 185, 195),
        ShinySilver = Color3.fromRGB(220, 225, 235),
        ChromeHighlight = Color3.fromRGB(255, 255, 255),
        DarkChrome = Color3.fromRGB(50, 55, 65)
    }

    local Main = Instance.new("Frame")
    Main.Name = "Main"
    Main.Size = UDim2.new(0.85, 0, 0, 140)
    Main.Position = UDim2.new(0.5, 0, 0.5, 0)
    Main.AnchorPoint = Vector2.new(0.5, 0.5)
    Main.BackgroundColor3 = Theme.MainBg
    Main.BorderSizePixel = 0
    Main.ClipsDescendants = false
    Main.Parent = ScreenGui

    local MainSizeConstraint = Instance.new("UISizeConstraint")
    MainSizeConstraint.MaxSize = Vector2.new(380, 2000)
    MainSizeConstraint.Parent = Main

    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 14)
    MainCorner.Parent = Main

    -- Brushed Metal Background Gradient
    local MainBgGradient = Instance.new("UIGradient")
    MainBgGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(35, 38, 45)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(18, 20, 24)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 11, 14))
    })
    MainBgGradient.Rotation = 135
    MainBgGradient.Parent = Main

    local MainStroke = Instance.new("UIStroke")
    MainStroke.Thickness = 2
    MainStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    MainStroke.Parent = Main

    -- Animated Chrome Metallic Border
    local StrokeGradient = Instance.new("UIGradient")
    StrokeGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(0.2, Color3.fromRGB(130, 140, 160)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(0.8, Color3.fromRGB(90, 100, 120)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
    })
    StrokeGradient.Parent = MainStroke

    task.spawn(function()
        while Main and Main.Parent and ScreenGui and ScreenGui.Parent do
            for i = 0, 360, 2 do
                if not StrokeGradient or not StrokeGradient.Parent then break end
                StrokeGradient.Rotation = i
                task.wait(0.02)
            end
        end
    end)

    local HeaderHitbox = Instance.new("TextButton")
    HeaderHitbox.Size = UDim2.new(1, 0, 0, 45)
    HeaderHitbox.BackgroundTransparency = 1
    HeaderHitbox.Text = ""
    HeaderHitbox.Parent = Main

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, -95, 0, 18)
    Title.Position = UDim2.fromOffset(16, 12)
    Title.BackgroundTransparency = 1
    Title.Text = HubTitle or "CHROME UNIVERSAL"
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 13
    Title.TextColor3 = Theme.TextPrimary
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = Main

    local TitleGlow = Instance.new("UIStroke")
    TitleGlow.Color = Theme.ShinySilver
    TitleGlow.Thickness = 0.5
    TitleGlow.Parent = Title

    local Subtitle = Instance.new("TextLabel")
    Subtitle.Size = UDim2.new(1, -95, 0, 12)
    Subtitle.Position = UDim2.fromOffset(16, 28)
    Subtitle.BackgroundTransparency = 1
    Subtitle.Text = HubSubtitle or "Silver Metallic Edition"
    Subtitle.Font = Enum.Font.GothamMedium
    Subtitle.TextSize = 9
    Subtitle.TextColor3 = Theme.TextSecondary
    Subtitle.TextXAlignment = Enum.TextXAlignment.Left
    Subtitle.Parent = Main

    local Controls = Instance.new("Frame")
    Controls.Size = UDim2.fromOffset(60, 24)
    Controls.Position = UDim2.new(1, -72, 0, 12)
    Controls.BackgroundTransparency = 1
    Controls.Parent = Main

    local ControlsLayout = Instance.new("UIListLayout")
    ControlsLayout.FillDirection = Enum.FillDirection.Horizontal
    ControlsLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
    ControlsLayout.Padding = UDim.new(0, 8)
    ControlsLayout.Parent = Controls

    local Minimize = Instance.new("TextButton")
    Minimize.Size = UDim2.fromOffset(24, 24)
    Minimize.BackgroundColor3 = Theme.ElementBg
    Minimize.Text = "−"
    Minimize.TextColor3 = Theme.ShinySilver
    Minimize.Font = Enum.Font.GothamBold
    Minimize.TextSize = 14
    Minimize.BorderSizePixel = 0
    Minimize.LayoutOrder = 1
    Minimize.Parent = Controls
    Instance.new("UICorner", Minimize).CornerRadius = UDim.new(0, 6)
    local minStr = Instance.new("UIStroke", Minimize)
    minStr.Color = Theme.DarkChrome
    minStr.Thickness = 1

    local Close = Instance.new("TextButton")
    Close.Size = UDim2.fromOffset(24, 24)
    Close.BackgroundColor3 = Color3.fromRGB(45, 20, 25)
    Close.Text = "✕"
    Close.TextColor3 = Color3.fromRGB(255, 120, 130)
    Close.Font = Enum.Font.GothamBold
    Close.TextSize = 11
    Close.BorderSizePixel = 0
    Close.LayoutOrder = 2
    Close.Parent = Controls
    Instance.new("UICorner", Close).CornerRadius = UDim.new(0, 6)
    local clsStr = Instance.new("UIStroke", Close)
    clsStr.Color = Color3.fromRGB(160, 60, 70)
    clsStr.Thickness = 1

    Close.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

    -- TAB CONTAINER
    local TabContainer = Instance.new("ScrollingFrame")
    TabContainer.Size = UDim2.new(1, -32, 0, 28)
    TabContainer.Position = UDim2.fromOffset(16, 48)
    TabContainer.BackgroundTransparency = 1
    TabContainer.ScrollBarThickness = 0
    TabContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
    TabContainer.AutomaticCanvasSize = Enum.AutomaticSize.X
    TabContainer.Parent = Main

    local TabLayout = Instance.new("UIListLayout")
    TabLayout.FillDirection = Enum.FillDirection.Horizontal
    TabLayout.Padding = UDim.new(0, 6)
    TabLayout.Parent = TabContainer

    -- CONTENT HOLDER
    local ContentHolder = Instance.new("Frame")
    ContentHolder.Size = UDim2.new(1, -32, 1, -135)
    ContentHolder.Position = UDim2.fromOffset(16, 84)
    ContentHolder.BackgroundTransparency = 1
    ContentHolder.ClipsDescendants = true
    ContentHolder.Parent = Main

    -- PROFILE & INFO SECTION
    local ProfileFrame = Instance.new("Frame")
    ProfileFrame.Size = UDim2.new(1, -32, 0, 36)
    ProfileFrame.Position = UDim2.new(0, 16, 1, -46)
    ProfileFrame.BackgroundColor3 = Color3.fromRGB(20, 21, 25)
    ProfileFrame.BorderSizePixel = 0
    ProfileFrame.Parent = Main
    Instance.new("UICorner", ProfileFrame).CornerRadius = UDim.new(0, 8)
    local profStr = Instance.new("UIStroke", ProfileFrame)
    profStr.Color = Theme.DarkChrome
    profStr.Thickness = 1

    local AvatarImage = Instance.new("ImageLabel")
    AvatarImage.Size = UDim2.fromOffset(24, 24)
    AvatarImage.Position = UDim2.new(0, 8, 0.5, -12)
    AvatarImage.BackgroundColor3 = Theme.ElementBg
    AvatarImage.BorderSizePixel = 0
    AvatarImage.Parent = ProfileFrame
    Instance.new("UICorner", AvatarImage).CornerRadius = UDim.new(1, 0)

    task.spawn(function()
        local success, content = pcall(function()
            return Players:GetUserThumbnailAsync(Player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
        end)
        if success then AvatarImage.Image = content end
    end)

    local DisplayNameLabel = Instance.new("TextLabel")
    DisplayNameLabel.Size = UDim2.new(1, -90, 0, 14)
    DisplayNameLabel.Position = UDim2.fromOffset(40, 4)
    DisplayNameLabel.BackgroundTransparency = 1
    DisplayNameLabel.Text = Player.DisplayName
    DisplayNameLabel.Font = Enum.Font.GothamBold
    DisplayNameLabel.TextSize = 10
    DisplayNameLabel.TextColor3 = Theme.TextPrimary
    DisplayNameLabel.TextXAlignment = Enum.TextXAlignment.Left
    DisplayNameLabel.Parent = ProfileFrame

    local UsernameLabel = Instance.new("TextLabel")
    UsernameLabel.Size = UDim2.new(1, -90, 0, 12)
    UsernameLabel.Position = UDim2.fromOffset(40, 18)
    UsernameLabel.BackgroundTransparency = 1
    UsernameLabel.Text = "@" .. Player.Name
    UsernameLabel.Font = Enum.Font.GothamMedium
    UsernameLabel.TextSize = 8.5
    UsernameLabel.TextColor3 = Theme.TextSecondary
    UsernameLabel.TextXAlignment = Enum.TextXAlignment.Left
    UsernameLabel.Parent = ProfileFrame

    -- PLAYER INFO POPUP MODAL
    local InfoButton = Instance.new("TextButton")
    InfoButton.Size = UDim2.fromOffset(24, 24)
    InfoButton.Position = UDim2.new(1, -32, 0.5, -12)
    InfoButton.BackgroundColor3 = Color3.fromRGB(35, 38, 45)
    InfoButton.Text = "ℹ"
    InfoButton.TextColor3 = Theme.ShinySilver
    InfoButton.Font = Enum.Font.GothamBold
    InfoButton.TextSize = 12
    InfoButton.BorderSizePixel = 0
    InfoButton.Parent = ProfileFrame
    Instance.new("UICorner", InfoButton).CornerRadius = UDim.new(0, 6)
    local infoStr = Instance.new("UIStroke", InfoButton)
    infoStr.Color = Theme.ShinySilver
    infoStr.Thickness = 0.8

    local InfoModal = Instance.new("Frame")
    InfoModal.Size = UDim2.new(1, -32, 0, 110)
    InfoModal.Position = UDim2.new(0, 16, 1, -165)
    InfoModal.BackgroundColor3 = Color3.fromRGB(18, 20, 24)
    InfoModal.BorderSizePixel = 0
    InfoModal.Visible = false
    InfoModal.ZIndex = 10
    InfoModal.Parent = Main
    Instance.new("UICorner", InfoModal).CornerRadius = UDim.new(0, 8)
    local modalStr = Instance.new("UIStroke", InfoModal)
    modalStr.Color = Theme.ShinySilver
    modalStr.Thickness = 1.5

    -- Calculate account creation date accurately
    local accountAgeDays = Player.AccountAge
    local createDate = os.date("%B %d, %Y", os.time() - (accountAgeDays * 86400))
    local execName = (identifyexecutor and identifyexecutor()) or "Unknown Executor"

    local InfoText = Instance.new("TextLabel")
    InfoText.Size = UDim2.new(1, -16, 1, -16)
    InfoText.Position = UDim2.fromOffset(8, 8)
    InfoText.BackgroundTransparency = 1
    InfoText.Font = Enum.Font.GothamMedium
    InfoText.TextSize = 10
    InfoText.TextColor3 = Theme.ShinySilver
    InfoText.TextXAlignment = Enum.TextXAlignment.Left
    InfoText.TextYAlignment = Enum.TextYAlignment.Top
    InfoText.ZIndex = 11
    InfoText.Text = string.format(
        "** USER DOSSIER **\n\nUser ID: %s\nAccount Age: %d Days\nCreated On: %s\nExecutor: %s",
        tostring(Player.UserId),
        accountAgeDays,
        createDate,
        tostring(execName)
    )
    InfoText.Parent = InfoModal

    InfoButton.MouseButton1Click:Connect(function()
        InfoModal.Visible = not InfoModal.Visible
        if InfoModal.Visible then
            InfoModal.Position = UDim2.new(0, 16, 1, -155)
            TweenService:Create(InfoModal, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 16, 1, -165)}):Play()
        end
    end)

    -- DRAG & SIZE LOGIC
    local dragging, dragInput, dragStart, startPos
    HeaderHitbox.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = Main.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    HeaderHitbox.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
    UIS.InputChanged:Connect(function(input) if input == dragInput and dragging then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end end)

    local Window = { Tabs = {}, ActiveTab = nil, MaxHeight = 140 }

    local function UpdateSize()
        task.wait()
        if not Window.ActiveTab then return end
        local contentHeight = Window.ActiveTab.Layout.AbsoluteContentSize.Y
        Window.MaxHeight = math.max(145, 145 + contentHeight)
        if not Minimized then
            TweenService:Create(Main, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(Main.Size.X.Scale, 0, 0, Window.MaxHeight)}):Play()
        end
    end

    Minimize.MouseButton1Click:Connect(function()
        Minimized = not Minimized
        if Minimized then
            InfoModal.Visible = false
            TweenService:Create(Main, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(Main.Size.X.Scale, 0, 0, 45)}):Play()
            ContentHolder.Visible = false; ProfileFrame.Visible = false; TabContainer.Visible = false; Minimize.Text = "+"
        else
            ContentHolder.Visible = true; ProfileFrame.Visible = true; TabContainer.Visible = true; Minimize.Text = "−"
            TweenService:Create(Main, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(Main.Size.X.Scale, 0, 0, Window.MaxHeight)}):Play()
        end
    end)
    -- === PART 2 STARTS HERE ===
    function Window:CreateTab(TabName)
        local TabButton = Instance.new("TextButton")
        TabButton.Size = UDim2.new(0, 0, 1, 0)
        TabButton.AutomaticSize = Enum.AutomaticSize.X
        TabButton.BackgroundColor3 = Color3.fromRGB(25, 28, 35)
        TabButton.Text = "  " .. TabName .. "  "
        TabButton.Font = Enum.Font.GothamBold
        TabButton.TextSize = 11
        TabButton.TextColor3 = Theme.TextSecondary
        TabButton.BorderSizePixel = 0
        TabButton.Parent = TabContainer
        Instance.new("UICorner", TabButton).CornerRadius = UDim.new(0, 6)
        
        local tabStr = Instance.new("UIStroke", TabButton)
        tabStr.Color = Theme.DarkChrome
        tabStr.Thickness = 1

        local TabPage = Instance.new("Frame")
        TabPage.Size = UDim2.new(1, 0, 1, 0)
        TabPage.BackgroundTransparency = 1
        TabPage.Visible = false
        TabPage.Parent = ContentHolder

        local PageLayout = Instance.new("UIListLayout")
        PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        PageLayout.Padding = UDim.new(0, 8)
        PageLayout.Parent = TabPage

        local Tab = { Layout = PageLayout }

        local function ActivateTab()
            for _, t in pairs(Window.Tabs) do
                t.Page.Visible = false
                t.Button.TextColor3 = Theme.TextSecondary
                t.Button.BackgroundColor3 = Color3.fromRGB(25, 28, 35)
                t.Stroke.Color = Theme.DarkChrome
            end
            TabPage.Visible = true
            TabButton.TextColor3 = Theme.TextPrimary
            TabButton.BackgroundColor3 = Color3.fromRGB(45, 50, 60)
            tabStr.Color = Theme.ShinySilver
            Window.ActiveTab = Tab
            UpdateSize()
        end

        TabButton.MouseButton1Click:Connect(ActivateTab)
        table.insert(Window.Tabs, {Page = TabPage, Button = TabButton, Stroke = tabStr})

        if #Window.Tabs == 1 then ActivateTab() end

        -- ELEMENTS INSIDE TABS
        function Tab:CreateSection(SectionName)
            local SectionFrame = Instance.new("Frame")
            SectionFrame.Size = UDim2.new(1, 0, 0, 22)
            SectionFrame.BackgroundTransparency = 1
            SectionFrame.Parent = TabPage

            local LineLeft = Instance.new("Frame")
            LineLeft.Size = UDim2.new(0.05, 0, 0, 1)
            LineLeft.Position = UDim2.new(0, 0, 0.5, 0)
            LineLeft.BackgroundColor3 = Theme.DarkChrome
            LineLeft.BorderSizePixel = 0
            LineLeft.Parent = SectionFrame

            local LabelText = Instance.new("TextLabel")
            LabelText.Size = UDim2.new(0.85, 0, 1, 0)
            LabelText.Position = UDim2.new(0.08, 0, 0, 0)
            LabelText.BackgroundTransparency = 1
            LabelText.Text = SectionName
            LabelText.Font = Enum.Font.GothamBold
            LabelText.TextSize = 10
            LabelText.TextColor3 = Theme.ShinySilver
            LabelText.TextXAlignment = Enum.TextXAlignment.Left
            LabelText.Parent = SectionFrame

            local LineRight = Instance.new("Frame")
            LineRight.Size = UDim2.new(0.3, 0, 0, 1)
            LineRight.Position = UDim2.new(0.7, 0, 0.5, 0)
            LineRight.BackgroundColor3 = Theme.DarkChrome
            LineRight.BorderSizePixel = 0
            LineRight.Parent = SectionFrame

            UpdateSize()
        end

        function Tab:CreateButton(Name, Callback)
            local ButtonFrame = Instance.new("TextButton")
            ButtonFrame.Size = UDim2.new(1, 0, 0, 34)
            ButtonFrame.BackgroundColor3 = Theme.ElementBg
            ButtonFrame.BorderSizePixel = 0
            ButtonFrame.ClipsDescendants = true
            ButtonFrame.Text = ""
            ButtonFrame.Parent = TabPage
            Instance.new("UICorner", ButtonFrame).CornerRadius = UDim.new(0, 8)

            local BaseGradient = Instance.new("UIGradient")  
            BaseGradient.Color = ColorSequence.new({  
                ColorSequenceKeypoint.new(0, Color3.fromRGB(60, 65, 80)),  
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(35, 38, 45)),  
                ColorSequenceKeypoint.new(1, Color3.fromRGB(20, 22, 26))  
            })  
            BaseGradient.Rotation = 90  
            BaseGradient.Parent = ButtonFrame  

            local Stroke = Instance.new("UIStroke")  
            Stroke.Color = Theme.DarkChrome  
            Stroke.Thickness = 1  
            Stroke.Parent = ButtonFrame  

            local Label = Instance.new("TextLabel")  
            Label.Size = UDim2.new(1, 0, 1, 0)  
            Label.BackgroundTransparency = 1  
            Label.Text = Name  
            Label.Font = Enum.Font.GothamBold  
            Label.TextSize = 11  
            Label.TextColor3 = Theme.TextPrimary 
            Label.Parent = ButtonFrame
            
            ButtonFrame.MouseButton1Click:Connect(function()
                TweenService:Create(Stroke, TweenInfo.new(0.1), {Color = Theme.ShinySilver}):Play()
                task.delay(0.15, function() TweenService:Create(Stroke, TweenInfo.new(0.2), {Color = Theme.DarkChrome}):Play() end)
                if Callback then pcall(Callback) end
            end)
            UpdateSize()
        end

        function Tab:CreateToggle(Name, Callback)
            local ButtonFrame = Instance.new("TextButton")
            ButtonFrame.Size = UDim2.new(1, 0, 0, 34)
            ButtonFrame.BackgroundColor3 = Theme.ElementBg
            ButtonFrame.BorderSizePixel = 0
            ButtonFrame.Text = ""
            ButtonFrame.Parent = TabPage
            Instance.new("UICorner", ButtonFrame).CornerRadius = UDim.new(0, 8)

            local Stroke = Instance.new("UIStroke")  
            Stroke.Color = Theme.DarkChrome
            Stroke.Thickness = 1
            Stroke.Parent = ButtonFrame  

            local Label = Instance.new("TextLabel")  
            Label.Size = UDim2.new(1, -60, 1, 0)  
            Label.Position = UDim2.fromOffset(12, 0)  
            Label.BackgroundTransparency = 1  
            Label.Text = Name
            Label.Font = Enum.Font.GothamBold  
            Label.TextSize = 11
            Label.TextColor3 = Theme.TextPrimary 
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = ButtonFrame  

            local SwitchTrack = Instance.new("Frame")
            SwitchTrack.Size = UDim2.fromOffset(36, 18)
            SwitchTrack.Position = UDim2.new(1, -48, 0.5, -9)
            SwitchTrack.BackgroundColor3 = Color3.fromRGB(30, 33, 40)
            SwitchTrack.BorderSizePixel = 0
            SwitchTrack.Parent = ButtonFrame
            Instance.new("UICorner", SwitchTrack).CornerRadius = UDim.new(1, 0)

            local SwitchKnob = Instance.new("Frame")
            SwitchKnob.Size = UDim2.fromOffset(14, 14)
            SwitchKnob.Position = UDim2.fromOffset(2, 2)
            SwitchKnob.BackgroundColor3 = Theme.TextSecondary
            SwitchKnob.BorderSizePixel = 0
            SwitchKnob.Parent = SwitchTrack
            Instance.new("UICorner", SwitchKnob).CornerRadius = UDim.new(1, 0)

            local ToggledState = false
            ButtonFrame.MouseButton1Click:Connect(function()  
                ToggledState = not ToggledState
                if ToggledState then
                    TweenService:Create(Stroke, TweenInfo.new(0.15), {Color = Theme.ShinySilver}):Play()
                    TweenService:Create(SwitchTrack, TweenInfo.new(0.15), {BackgroundColor3 = Theme.ShinySilver}):Play()
                    TweenService:Create(SwitchKnob, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.fromOffset(20, 2), BackgroundColor3 = Color3.fromRGB(15, 15, 18)}):Play()
                else
                    TweenService:Create(Stroke, TweenInfo.new(0.15), {Color = Theme.DarkChrome}):Play()
                    TweenService:Create(SwitchTrack, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(30, 33, 40)}):Play()
                    TweenService:Create(SwitchKnob, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.fromOffset(2, 2), BackgroundColor3 = Theme.TextSecondary}):Play()
                end
                if Callback then pcall(Callback, ToggledState) end
            end)  
            UpdateSize()
        end

        function Tab:CreateSlider(Name, Min, Max, Default, Callback)
            local SliderFrame = Instance.new("Frame")
            SliderFrame.Size = UDim2.new(1, 0, 0, 44)
            SliderFrame.BackgroundColor3 = Theme.ElementBg
            SliderFrame.BorderSizePixel = 0
            SliderFrame.Parent = TabPage
            Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 8)

            local Stroke = Instance.new("UIStroke")
            Stroke.Color = Theme.DarkChrome
            Stroke.Thickness = 1
            Stroke.Parent = SliderFrame

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(1, -60, 0, 20)
            Label.Position = UDim2.fromOffset(12, 4)
            Label.BackgroundTransparency = 1
            Label.Text = Name
            Label.Font = Enum.Font.GothamBold
            Label.TextSize = 11
            Label.TextColor3 = Theme.TextPrimary
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = SliderFrame

            local ValueLabel = Instance.new("TextLabel")
            ValueLabel.Size = UDim2.new(0, 40, 0, 20)
            ValueLabel.Position = UDim2.new(1, -52, 0, 4)
            ValueLabel.BackgroundTransparency = 1
            ValueLabel.Text = tostring(Default or Min)
            ValueLabel.Font = Enum.Font.GothamBold
            ValueLabel.TextSize = 11
            ValueLabel.TextColor3 = Theme.ShinySilver
            ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
            ValueLabel.Parent = SliderFrame

            local Track = Instance.new("TextButton")
            Track.Size = UDim2.new(1, -24, 0, 8)
            Track.Position = UDim2.new(0, 12, 0, 28)
            Track.BackgroundColor3 = Color3.fromRGB(30, 33, 40)
            Track.BorderSizePixel = 0
            Track.Text = ""
            Track.Parent = SliderFrame
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local Fill = Instance.new("Frame")
            local startScale = math.clamp(((Default or Min) - Min) / (Max - Min), 0, 1)
            Fill.Size = UDim2.new(startScale, 0, 1, 0)
            Fill.BackgroundColor3 = Theme.ShinySilver
            Fill.BorderSizePixel = 0
            Fill.Parent = Track
            Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

            local isDragging = false
            local function UpdateVal(input)
                local pos = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                local val = math.floor(Min + ((Max - Min) * pos))
                ValueLabel.Text = tostring(val)
                TweenService:Create(Fill, TweenInfo.new(0.05, Enum.EasingStyle.Quad), {Size = UDim2.new(pos, 0, 1, 0)}):Play()
                if Callback then pcall(Callback, val) end
            end

            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging = true; TweenService:Create(Stroke, TweenInfo.new(0.15), {Color = Theme.ShinySilver}):Play(); UpdateVal(input)
                end
            end)
            UIS.InputEnded:Connect(function(input)
                if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and isDragging then
                    isDragging = false; TweenService:Create(Stroke, TweenInfo.new(0.15), {Color = Theme.DarkChrome}):Play()
                end
            end)
            UIS.InputChanged:Connect(function(input) if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then UpdateVal(input) end end)
            UpdateSize()
        end

        function Tab:CreateTextBox(Name, Placeholder, Callback)
            local BoxFrame = Instance.new("Frame")
            BoxFrame.Size = UDim2.new(1, 0, 0, 38)
            BoxFrame.BackgroundColor3 = Theme.ElementBg
            BoxFrame.BorderSizePixel = 0
            BoxFrame.Parent = TabPage
            Instance.new("UICorner", BoxFrame).CornerRadius = UDim.new(0, 8)

            local Stroke = Instance.new("UIStroke")
            Stroke.Color = Theme.DarkChrome; Stroke.Thickness = 1; Stroke.Parent = BoxFrame

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(0.5, -12, 1, 0)
            Label.Position = UDim2.fromOffset(12, 0)
            Label.BackgroundTransparency = 1; Label.Text = Name; Label.Font = Enum.Font.GothamBold; Label.TextSize = 11; Label.TextColor3 = Theme.TextPrimary; Label.TextXAlignment = Enum.TextXAlignment.Left; Label.Parent = BoxFrame

            local InputBg = Instance.new("Frame")
            InputBg.Size = UDim2.new(0.45, 0, 0, 24)
            InputBg.Position = UDim2.new(0.55, -8, 0.5, -12)
            InputBg.BackgroundColor3 = Color3.fromRGB(15, 15, 18); InputBg.BorderSizePixel = 0; InputBg.Parent = BoxFrame
            Instance.new("UICorner", InputBg).CornerRadius = UDim.new(0, 6)
            local InputStroke = Instance.new("UIStroke", InputBg); InputStroke.Color = Theme.DarkChrome; InputStroke.Thickness = 1

            local TextBox = Instance.new("TextBox")
            TextBox.Size = UDim2.new(1, -10, 1, 0); TextBox.Position = UDim2.fromOffset(5, 0); TextBox.BackgroundTransparency = 1; TextBox.Text = ""; TextBox.PlaceholderText = Placeholder or "Type..."; TextBox.PlaceholderColor3 = Color3.fromRGB(100, 105, 115); TextBox.Font = Enum.Font.GothamMedium; TextBox.TextSize = 10; TextBox.TextColor3 = Theme.ShinySilver; TextBox.TextXAlignment = Enum.TextXAlignment.Left; TextBox.ClearTextOnFocus = false; TextBox.Parent = InputBg

            TextBox.Focused:Connect(function() TweenService:Create(InputStroke, TweenInfo.new(0.15), {Color = Theme.ShinySilver}):Play() end)
            TextBox.FocusLost:Connect(function(enter) TweenService:Create(InputStroke, TweenInfo.new(0.15), {Color = Theme.DarkChrome}):Play(); if Callback then pcall(Callback, TextBox.Text, enter) end end)
            UpdateSize()
        end

        function Tab:CreateDropdown(Name, Options, Callback)
            local DropdownFrame = Instance.new("Frame")
            DropdownFrame.Size = UDim2.new(1, 0, 0, 34); DropdownFrame.BackgroundColor3 = Theme.ElementBg; DropdownFrame.BorderSizePixel = 0; DropdownFrame.ClipsDescendants = true; DropdownFrame.Parent = TabPage
            Instance.new("UICorner", DropdownFrame).CornerRadius = UDim.new(0, 8)

            local Stroke = Instance.new("UIStroke", DropdownFrame); Stroke.Color = Theme.DarkChrome; Stroke.Thickness = 1

            local HeaderButton = Instance.new("TextButton")
            HeaderButton.Size = UDim2.new(1, 0, 0, 34); HeaderButton.BackgroundTransparency = 1; HeaderButton.Text = ""; HeaderButton.Parent = DropdownFrame

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(1, -40, 1, 0); Label.Position = UDim2.fromOffset(12, 0); Label.BackgroundTransparency = 1; Label.Text = Name .. " : None"; Label.Font = Enum.Font.GothamBold; Label.TextSize = 11; Label.TextColor3 = Theme.TextPrimary; Label.TextXAlignment = Enum.TextXAlignment.Left; Label.Parent = HeaderButton

            local Arrow = Instance.new("TextLabel")
            Arrow.Size = UDim2.new(0, 20, 1, 0); Arrow.Position = UDim2.new(1, -28, 0, 0); Arrow.BackgroundTransparency = 1; Arrow.Text = "▼"; Arrow.Font = Enum.Font.GothamBold; Arrow.TextSize = 10; Arrow.TextColor3 = Theme.ShinySilver; Arrow.Parent = HeaderButton

            local OptionContainer = Instance.new("Frame")
            OptionContainer.Size = UDim2.new(1, -24, 0, #Options * 26); OptionContainer.Position = UDim2.fromOffset(12, 36); OptionContainer.BackgroundTransparency = 1; OptionContainer.Parent = DropdownFrame
            local OptLayout = Instance.new("UIListLayout", OptionContainer); OptLayout.SortOrder = Enum.SortOrder.LayoutOrder; OptLayout.Padding = UDim.new(0, 4)

            local Expanded = false
            local function ToggleDrop()
                Expanded = not Expanded
                local targetH = Expanded and (44 + (#Options * 28)) or 34
                TweenService:Create(DropdownFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.new(1, 0, 0, targetH)}):Play()
                TweenService:Create(Arrow, TweenInfo.new(0.2), {Rotation = Expanded and 180 or 0}):Play()
                TweenService:Create(Stroke, TweenInfo.new(0.2), {Color = Expanded and Theme.ShinySilver or Theme.DarkChrome}):Play()
                task.delay(0.1, function() UpdateSize() end)
            end
            HeaderButton.MouseButton1Click:Connect(ToggleDrop)

            for _, opt in ipairs(Options) do
                local OptBtn = Instance.new("TextButton")
                OptBtn.Size = UDim2.new(1, 0, 0, 24); OptBtn.BackgroundColor3 = Color3.fromRGB(30, 33, 40); OptBtn.Text = opt; OptBtn.Font = Enum.Font.GothamMedium; OptBtn.TextSize = 10; OptBtn.TextColor3 = Theme.TextSecondary; OptBtn.BorderSizePixel = 0; OptBtn.Parent = OptionContainer
                Instance.new("UICorner", OptBtn).CornerRadius = UDim.new(0, 6)
                OptBtn.MouseButton1Click:Connect(function() Label.Text = Name .. " : " .. opt; if Callback then pcall(Callback, opt) end; ToggleDrop() end)
            end
            UpdateSize()
        end

        return Tab
    end

    return Window
end

return Library
