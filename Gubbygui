local Library = {}

function Library:CreateWindow(HubTitle, HubSubtitle)
    local Players = game:GetService("Players")
    local UIS = game:GetService("UserInputService")
    local CoreGui = game:GetService("CoreGui")
    local TweenService = game:GetService("TweenService")

    local Player = Players.LocalPlayer

    -- Easter Egg Condition Verification
    local isSpecialUser = (Player.Name == "Tester_ugcAccount")
    local displayName = isSpecialUser and "Gubby_scripter" or Player.DisplayName

    local ParentFolder
    if gethui then
        ParentFolder = gethui()
    elseif cloneref then
        local success, core = pcall(cloneref, CoreGui)
        ParentFolder = success and core or Player:WaitForChild("PlayerGui")
    else
        local success, core = pcall(function() return CoreGui:ClassName() == "CoreGui" and CoreGui end)
        ParentFolder = success and core or Player:WaitForChild("PlayerGui")
    end

    pcall(function()
        if ParentFolder:FindFirstChild("UniversalGui") then
            ParentFolder.UniversalGui:Destroy()
        end
    end)

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "UniversalGui"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = ParentFolder

    -- =========================================================================
    -- MAIN WINDOW (CLEAN, COMPACT CONFIGURATION FOR PC & MOBILE)
    -- =========================================================================
    local Main = Instance.new("Frame")
    Main.Name = "Main"
    Main.Size = UDim2.fromOffset(330, 95)
    Main.Position = UDim2.new(0.5, -165, 0.45, -47)
    Main.BackgroundColor3 = Color3.fromRGB(11, 9, 17)
    Main.BorderSizePixel = 0
    Main.ClipsDescendants = true
    Main.Parent = ScreenGui

    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 9)
    MainCorner.Parent = Main

    local MainBgGradient = Instance.new("UIGradient")
    MainBgGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 15, 32)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(12, 10, 18)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(7, 6, 11))
    })
    MainBgGradient.Rotation = 45
    MainBgGradient.Parent = Main

    local MainStroke = Instance.new("UIStroke")
    MainStroke.Thickness = 1.1
    MainStroke.Color = Color3.fromRGB(255, 255, 255)
    MainStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    MainStroke.Parent = Main

    local MainStrokeGradient = Instance.new("UIGradient")
    MainStrokeGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(180, 140, 255)),
        ColorSequenceKeypoint.new(0.4, Color3.fromRGB(70, 55, 95)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(22, 18, 30))
    })
    MainStrokeGradient.Rotation = 45
    MainStrokeGradient.Parent = MainStroke

    local AmbientGlow = Instance.new("Frame")
    AmbientGlow.Name = "AmbientGlow"
    AmbientGlow.Size = UDim2.new(1, 8, 1, 8)
    AmbientGlow.Position = UDim2.fromOffset(-4, -4)
    AmbientGlow.BackgroundColor3 = Color3.fromRGB(115, 60, 255)
    AmbientGlow.BackgroundTransparency = 0.92
    AmbientGlow.ZIndex = Main.ZIndex - 1
    AmbientGlow.Parent = Main

    local GlowCorner = Instance.new("UICorner")
    GlowCorner.CornerRadius = UDim.new(0, 11)
    GlowCorner.Parent = AmbientGlow

    -- Header Layout Block
    local HeaderFrame = Instance.new("Frame")
    HeaderFrame.Name = "HeaderFrame"
    HeaderFrame.Size = UDim2.new(1, 0, 0, 50)
    HeaderFrame.BackgroundTransparency = 1
    HeaderFrame.Parent = Main

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, -60, 0, 18)
    Title.Position = UDim2.fromOffset(14, 13)
    Title.BackgroundTransparency = 1
    Title.Text = HubTitle or "UNIVERSAL GUI"
    Title.Font = Enum.Font.GothamBlack
    Title.TextSize = 12
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = HeaderFrame

    local Subtitle = Instance.new("TextLabel")
    Subtitle.Size = UDim2.new(1, -60, 0, 12)
    Subtitle.Position = UDim2.fromOffset(14, 29)
    Subtitle.BackgroundTransparency = 1
    Subtitle.Text = HubSubtitle or "Made by Unknown"
    Subtitle.Font = Enum.Font.GothamMedium
    Subtitle.TextSize = 9
    Subtitle.TextColor3 = Color3.fromRGB(115, 105, 135)
    Subtitle.TextXAlignment = Enum.TextXAlignment.Left
    Subtitle.Parent = HeaderFrame

    local Minimize = Instance.new("TextButton")
    Minimize.Size = UDim2.fromOffset(22, 22)
    Minimize.Position = UDim2.new(1, -34, 0, 14)
    Minimize.BackgroundColor3 = Color3.fromRGB(22, 16, 32)
    Minimize.Text = "—"
    Minimize.TextColor3 = Color3.fromRGB(200, 195, 220)
    Minimize.Font = Enum.Font.GothamBold
    Minimize.TextSize = 10
    Minimize.BorderSizePixel = 0
    Minimize.Parent = HeaderFrame

    local MinCorner = Instance.new("UICorner")
    MinCorner.CornerRadius = UDim.new(0, 6)
    MinCorner.Parent = Minimize

    local MinimizeStroke = Instance.new("UIStroke")
    MinimizeStroke.Color = Color3.fromRGB(60, 50, 85)
    MinimizeStroke.Thickness = 1
    MinimizeStroke.Parent = Minimize

    local Content = Instance.new("Frame")
    Content.Size = UDim2.new(1, -28, 1, -95)
    Content.Position = UDim2.fromOffset(14, 52)
    Content.BackgroundTransparency = 1
    Content.Visible = false
    Content.Parent = Main

    -- =========================================================================
    -- EMBEDDED SNAPPY INTRO SYSTEM
    -- =========================================================================
    local WelcomeContainer = Instance.new("Frame")
    WelcomeContainer.Size = UDim2.new(1, 0, 0, 45)
    WelcomeContainer.Position = UDim2.fromOffset(0, 50)
    WelcomeContainer.BackgroundTransparency = 1
    WelcomeContainer.Parent = Main

    local FastWelcomeLabel = Instance.new("TextLabel")
    FastWelcomeLabel.Size = UDim2.new(1, 0, 1, 0)
    FastWelcomeLabel.BackgroundTransparency = 1
    FastWelcomeLabel.Text = "Welcome, " .. displayName
    FastWelcomeLabel.Font = Enum.Font.GothamBold
    FastWelcomeLabel.TextSize = 12
    FastWelcomeLabel.TextColor3 = Color3.fromRGB(175, 140, 255)
    FastWelcomeLabel.TextTransparency = 1
    FastWelcomeLabel.Parent = WelcomeContainer

    -- Live Rainbow Dynamic Loop Setup
    if isSpecialUser then
        task.spawn(function()
            while true do
                for i = 0, 1, 0.005 do
                    FastWelcomeLabel.TextColor3 = Color3.fromHSV(i, 0.75, 1)
                    task.wait(0.01)
                end
            end
        end)
    end

    local Window = {
        ElementCount = 0,
        MaxHeight = 95
    }

    local Minimized = false

    local function UpdateSize()
        Window.MaxHeight = 95 + (Window.ElementCount * 44)
        if not Minimized and Content.Visible then
            Main.Size = UDim2.fromOffset(330, Window.MaxHeight)
        end
    end

    task.spawn(function()
        Main.Size = UDim2.fromOffset(330, 50)
        TweenService:Create(Main, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.fromOffset(330, 95)}):Play()
        task.wait(0.05)
        TweenService:Create(FastWelcomeLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextTransparency = 0}):Play()
        
        task.wait(1.0)
        
        TweenService:Create(FastWelcomeLabel, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {TextTransparency = 1}):Play()
        task.wait(0.15)
        WelcomeContainer:Destroy()
        
        Content.Visible = true
        UpdateSize()
    end)

    function Window:CreateToggle(Name, Callback)
        local YPos = Window.ElementCount * 44
        Window.ElementCount = Window.ElementCount + 1
        UpdateSize()

        local ButtonFrame = Instance.new("TextButton")
        ButtonFrame.Name = "ToggleButton"
        ButtonFrame.Size = UDim2.new(1, 0, 0, 38)
        ButtonFrame.Position = UDim2.fromOffset(0, YPos)
        ButtonFrame.BackgroundColor3 = Color3.fromRGB(16, 14, 24)
        ButtonFrame.BorderSizePixel = 0
        ButtonFrame.Text = ""
        ButtonFrame.Parent = Content

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = ButtonFrame

        local BaseGradient = Instance.new("UIGradient")  
        BaseGradient.Color = ColorSequence.new({  
            ColorSequenceKeypoint.new(0, Color3.fromRGB(26, 18, 40)),  
            ColorSequenceKeypoint.new(1, Color3.fromRGB(14, 11, 20))  
        })  
        BaseGradient.Rotation = 90  
        BaseGradient.Parent = ButtonFrame  

        local Stroke = Instance.new("UIStroke")  
        Stroke.Color = Color3.fromRGB(48, 40, 70)
        Stroke.Thickness = 1  
        Stroke.Parent = ButtonFrame  

        local Label = Instance.new("TextLabel")  
        Label.Size = UDim2.new(1, -60, 1, 0)  
        Label.Position = UDim2.fromOffset(12, 0)  
        Label.BackgroundTransparency = 1  
        Label.Text = Name
        Label.Font = Enum.Font.GothamBold  
        Label.TextSize = 11  
        Label.TextColor3 = Color3.fromRGB(225, 220, 240) 
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = ButtonFrame  

        local SwitchTrack = Instance.new("Frame")
        SwitchTrack.Name = "SwitchTrack"
        SwitchTrack.Size = UDim2.fromOffset(34, 18)
        SwitchTrack.Position = UDim2.new(1, -46, 0.5, -9)
        SwitchTrack.BackgroundColor3 = Color3.fromRGB(35, 28, 48)
        SwitchTrack.BorderSizePixel = 0
        SwitchTrack.Parent = ButtonFrame

        local trackCorner = Instance.new("UICorner")
        trackCorner.CornerRadius = UDim.new(1, 0)
        trackCorner.Parent = SwitchTrack

        local SwitchKnob = Instance.new("Frame")
        SwitchKnob.Name = "SwitchKnob"
        SwitchKnob.Size = UDim2.fromOffset(12, 12)
        SwitchKnob.Position = UDim2.fromOffset(3, 3)
        SwitchKnob.BackgroundColor3 = Color3.fromRGB(160, 150, 175)
        SwitchKnob.BorderSizePixel = 0
        SwitchKnob.Parent = SwitchTrack

        local knobCorner = Instance.new("UICorner")
        knobCorner.CornerRadius = UDim.new(1, 0)
        knobCorner.Parent = SwitchKnob

        local ToggledState = false
        
        ButtonFrame.MouseButton1Click:Connect(function()  
            ToggledState = not ToggledState
            
            if ToggledState then
                TweenService:Create(SwitchTrack, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(120, 45, 245)}):Play()
                TweenService:Create(SwitchKnob, TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.fromOffset(19, 3), BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
            else
                TweenService:Create(SwitchTrack, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(35, 28, 48)}):Play()
                TweenService:Create(SwitchKnob, TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.fromOffset(3, 3), BackgroundColor3 = Color3.fromRGB(160, 150, 175)}):Play()
            end

            if Callback then
                pcall(Callback, ToggledState)
            end
        end)  
    end
    function Window:CreateButton(Name, Callback)
        local YPos = Window.ElementCount * 44
        Window.ElementCount = Window.ElementCount + 1
        UpdateSize()

        local ButtonFrame = Instance.new("TextButton")
        ButtonFrame.Name = "SimpleButton"
        ButtonFrame.Size = UDim2.new(1, 0, 0, 38)
        ButtonFrame.Position = UDim2.fromOffset(0, YPos)
        ButtonFrame.BackgroundColor3 = Color3.fromRGB(20, 16, 30)
        ButtonFrame.BorderSizePixel = 0
        ButtonFrame.ClipsDescendants = true
        ButtonFrame.Text = ""
        ButtonFrame.Parent = Content

        local bCorner = Instance.new("UICorner")
        bCorner.CornerRadius = UDim.new(0, 6)
        bCorner.Parent = ButtonFrame

        local BaseGradient = Instance.new("UIGradient")  
        BaseGradient.Color = ColorSequence.new({  
            ColorSequenceKeypoint.new(0, Color3.fromRGB(38, 25, 58)),  
            ColorSequenceKeypoint.new(1, Color3.fromRGB(18, 12, 28))  
        })  
        BaseGradient.Rotation = 90  
        BaseGradient.Parent = ButtonFrame  

        local Stroke = Instance.new("UIStroke")  
        Stroke.Color = Color3.fromRGB(55, 42, 80)  
        Stroke.Thickness = 1  
        Stroke.Parent = ButtonFrame  

        local SheenBar = Instance.new("Frame")  
        SheenBar.Name = "SheenBar"  
        SheenBar.Size = UDim2.new(2, 0, 1, 0)
        SheenBar.Position = UDim2.new(-2, 0, 0, 0)
        SheenBar.BackgroundTransparency = 0
        SheenBar.ZIndex = 2
        SheenBar.Parent = ButtonFrame  

        local ClickSheenGradient = Instance.new("UIGradient")  
        ClickSheenGradient.Color = ColorSequence.new({  
            ColorSequenceKeypoint.new(0, Color3.fromRGB(38, 25, 58)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(195, 155, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(18, 12, 28))
        })  
        ClickSheenGradient.Transparency = NumberSequence.new({  
            NumberSequenceKeypoint.new(0, 1),  
            NumberSequenceKeypoint.new(0.5, 0.4),
            NumberSequenceKeypoint.new(1, 1)  
        })  
        ClickSheenGradient.Rotation = 20  
        ClickSheenGradient.Parent = SheenBar  

        local Label = Instance.new("TextLabel")  
        Label.Size = UDim2.new(1, 0, 1, 0)  
        Label.BackgroundTransparency = 1  
        Label.Text = Name  
        Label.Font = Enum.Font.GothamBlack  
        Label.TextSize = 11  
        Label.TextColor3 = Color3.fromRGB(255, 255, 255) 
        Label.ZIndex = 3  
        Label.Parent = ButtonFrame  

        ButtonFrame.MouseButton1Click:Connect(function()  
            SheenBar.Position = UDim2.new(-2, 0, 0, 0)
            TweenService:Create(SheenBar, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(1, 0, 0, 0)}):Play()

            if Callback then
                pcall(Callback)
            end
        end)  
    end

    -- Smooth Dragging System (PC & Mobile Support)
    local dragging = false
    local dragInput, dragStart, startPos

    Main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position

            input.Changed:Connect(function()  
                if input.UserInputState == Enum.UserInputState.End then  
                    dragging = false  
                end  
            end)  
        end
    end)

    Main.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    Minimize.MouseButton1Click:Connect(function()
        Minimized = not Minimized
        Content.Visible = not Minimized
        
        if Minimized then
            TweenService:Create(Main, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.fromOffset(330, 50)}):Play()
            Minimize.Text = "+"
        else
            TweenService:Create(Main, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.fromOffset(330, Window.MaxHeight)}):Play()
            Minimize.Text = "—"
        end
    end)

    return Window
end

return Library
