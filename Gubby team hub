local tabRegistry = {}
local currentActiveButton = nil

local function switchTab(targetName)
    for name, tabElement in pairs(tabRegistry) do
        if name == targetName then
            tabElement.Page.Visible = true
            tabElement.Button.BackgroundColor3 = THEME.SurfaceAccent
            tabElement.Button.TextColor3 = THEME.Accent
            currentActiveButton = tabElement.Button
        else
            tabElement.Page.Visible = false
            tabElement.Button.BackgroundColor3 = THEME.Surface
            tabElement.Button.TextColor3 = THEME.TextMuted
        end
    end
end

local function RunScript(url)
    local success, err = pcall(function()
