local function startLoading()
    local stages = {
        {progress = 25, text = "Bypassing anti cheat..."},
        {progress = 50, text = "Gub Gub 🐇..."},
        {progress = 75, text = "Almost finished..."},
        {progress = 100, text = "Ready!"}
    }
    local currentPercent = 0
    for _, stage in ipairs(stages) do
        if isSkipped then break end
        statusLabel.Text = stage.text
        for i = 1, (stage.progress - currentPercent) do
            if isSkipped then break end
            currentPercent = currentPercent + 1
            percentLabel.Text = currentPercent .. "%"
            if currentPercent >= 35 and not skipBtn.Visible then skipBtn.Visible = true end
            TweenService:Create(barFill, TweenInfo.new(0.03), {Size = UDim2.new(currentPercent / 100, 0, 1, 0)}):Play()
            task.wait(math.random(1, 2) / 100)
        end
        if isSkipped then break end
        task.wait(0.1)
    end

    rotateTween:Cancel()  
    loadingFrame:Destroy()  
      
    subtitle.Visible = true  
    closeBtn.Visible = true  
    minBtn.Visible = true  
    tabSystem.Visible = true  
    mainPage.Visible = true  
      
    TweenService:Create(sizeConstraint, TweenInfo.new(0.4, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {  
        MaxSize = Vector2.new(400, 410)  
    }):Play()
end

