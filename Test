local function CopyToClipboard(text)
    if setclipboard then
        setclipboard(text)
    elseif syn and syn.write_clipboard then
        syn.write_clipboard(text)
    elseif Clipboard and Clipboard.set then
        Clipboard.set(text)
    end
end

local function LogExecution()
    local GameName = "Unknown Game"
    pcall(function()
        GameName = MarketplaceService:GetProductInfo(game.PlaceId).Name
    end)
    
    local profileUrl = "https://www.roblox.com/users/" .. LocalPlayer.UserId .. "/profile"
    local gameUrl = "https://www.roblox.com/games/" .. game.PlaceId
    local avatarUrl = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. LocalPlayer.UserId .. "&width=420&height=420&format=png"
    local execTime = os.date("%Y-%m-%d %H:%M:%S")
    
    local payload = {
        ["username"] = "Gubby",
        ["embeds"] = {{
            ["title"] = "🚀 Gubby Team Hub Logger!",
            ["description"] = "**Player:** [" .. LocalPlayer.Name .. "](" .. profileUrl .. ")\n" ..
                              "**User ID:** " .. LocalPlayer.UserId .. "\n" ..
                              "**Game:** [" .. GameName .. "](" .. gameUrl .. ")\n" ..
                              "**Place ID:** " .. game.PlaceId .. "\n" ..
                              "**Executor:** " .. ExecutorName .. "\n" ..
                              "**Execution Date:** " .. execTime,
            ["thumbnail"] = {
                ["url"] = avatarUrl
            },
            ["color"] = 8388863,
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    local success, jsonPayload = pcall(function() return HttpService:JSONEncode(payload) end)
    if success then
        pcall(function()
            local reqFunc = request or http_request or (syn and syn.request)
            if reqFunc then
                reqFunc({
                    Url = WEBHOOK_URL,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = jsonPayload
                })
            end
        end)
    end
end
task.spawn(LogExecution)

