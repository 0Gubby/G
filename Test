local function MakeShinyPurpleText(textObject)
    textObject.TextColor3 = Color3.fromRGB(255, 255, 255)
    local TextGradient = Instance.new("UIGradient")
    TextGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(170, 70, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(240, 200, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(150, 50, 230))
    })
    TextGradient.Rotation = 45
    TextGradient.Parent = textObject

    task.spawn(function()
        while textObject and textObject.Parent do
            TextGradient.Rotation = 0
            local tween = TweenService:Create(TextGradient, TweenInfo.new(8, Enum.EasingStyle.Linear), {Rotation = 360})
            tween:Play()
            tween.Completed:Wait()
        end
    end)
end

local function ApplyPurpleWhiteBorderAnimation(uiStroke, speed)
    uiStroke.Color = Color3.fromRGB(255, 255, 255)
    uiStroke.Enabled = true

    local BorderGradient = Instance.new("UIGradient")
    BorderGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(170, 60, 255)),
        ColorSequenceKeypoint.new(0.25, Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(170, 60, 255)),
        ColorSequenceKeypoint.new(0.75, Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(170, 60, 255))
    })
    BorderGradient.Parent = uiStroke

    task.spawn(function()
        while uiStroke and uiStroke.Parent do
            BorderGradient.Rotation = 0
            local tween = TweenService:Create(BorderGradient, TweenInfo.new(speed or 4, Enum.EasingStyle.Linear), {Rotation = 360})
            tween:Play()
            tween.Completed:Wait()
        end
    end)
end
