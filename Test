local function RunScript(url)
    local success, err = pcall(function() loadstring(game:HttpGet(url))() end)
    if not success then warn("Execution Error: " .. tostring(err)) end
end

local function AddScriptButton(name, url, layoutOrder)
    local Btn = Instance.new("TextButton")
    Btn.Name = name
    Btn.Size = UDim2.new(1, -5, 0, 30)
    Btn.BackgroundColor3 = Color3.fromRGB(26, 18, 38)
    Btn.BackgroundTransparency = 0.2
    Btn.Text = name
    Btn.TextSize = 12
    Btn.Font = Enum.Font.Arcade
    Btn.LayoutOrder = layoutOrder
    Btn.Parent = ScrollList
    MakeShinyPurpleText(Btn)

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 6)
    BtnCorner.Parent = Btn

    local BtnStroke = Instance.new("UIStroke")
    BtnStroke.Thickness = 1.5
    BtnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    BtnStroke.Parent = Btn
    ApplyPurpleWhiteBorderAnimation(BtnStroke, 5)

    Btn.MouseEnter:Connect(function()
        TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 32, 80), BackgroundTransparency = 0.1}):Play()
    end)

    Btn.MouseLeave:Connect(function()
        TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(26, 18, 38), BackgroundTransparency = 0.2}):Play()
    end)

    Btn.MouseButton1Click:Connect(function()
        RunScript(url)
    end)

    table.insert(scriptButtons, Btn)
end

